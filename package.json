{
  "name": "@theyahia/yandex-direct-mcp",
  "version": "3.0.0",
  "description": "MCP server for Yandex.Direct API v5 — 12 tools: campaigns, ad groups, ads, keywords, statistics, account. Bearer token auth.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "yandex-direct-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "modelcontextprotocol",
    "claude",
    "ai",
    "llm",
    "anthropic",
    "cursor",
    "ai-tools",
    "ai-agent",
    "russian-api",
    "yandex",
    "direct",
    "advertising",
    "ppc",
    "ads",
    "marketing",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/yandex-direct-mcp.git"
  },
  "homepage": "https://github.com/theYahia/yandex-direct-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
}
